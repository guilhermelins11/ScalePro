# Database Configuration - MEI
DB_USER_MEI=seu_usuario
DB_PASSWORD_MEI=sua_senha
DB_HOST_MEI=localhost
DB_PORT_MEI=5432
DB_NAME_MEI=scalepro_mei

# Database Configuration - Produtos
DB_USER_PROD=seu_usuario
DB_PASSWORD_PROD=sua_senha
DB_HOST_PROD=localhost
DB_PORT_PROD=5432
DB_NAME_PROD=scalepro_produtos

# Session Database
DB_USER_SESSION=seu_usuario
DB_PASSWORD_SESSION=sua_senha
DB_HOST_SESSION=localhost
DB_PORT_SESSION=5432
DB_NAME_SESSION=scalepro_session

# Server Configuration
PORT=3000
NODE_ENV=development

# Session Configuration
SESSION_SECRET=sua_chave_secreta_muito_segura
SESSION_TIMEOUT=1800000

# JWT Configuration
JWT_SECRET=sua_chave_secreta_jwt
JWT_EXPIRATION=7d

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=info
LOG_DIR=./logs
